# =============================================================
# FinBot — Variables de entorno
# Copia este archivo a .env y rellena los valores.
# =============================================================
# Cada servicio (LLM, visión, embeddings, STT, TTS) puede apuntar
# a un proveedor distinto. Si *_BASE_URL o *_API_KEY no están
# definidos, se usa el BASE_URL / API_KEY global como fallback.
# =============================================================

# -------------------------------------------------------------
# DEFAULT — fallback para cualquier servicio sin config propia
# -------------------------------------------------------------
# Ejemplos de proveedores compatibles con la API de OpenAI:
#   OpenAI:      https://api.openai.com/v1
#   NVIDIA NIM:  https://integrate.api.nvidia.com/v1
#   Ollama:      http://localhost:11434/v1
#   Groq:        https://api.groq.com/openai/v1
#   Together AI: https://api.together.xyz/v1
BASE_URL=https://api.openai.com/v1
API_KEY=sk-...

# -------------------------------------------------------------
# LLM — completions / chat
# -------------------------------------------------------------
# LLM_BASE_URL=   # descomenta para usar un proveedor distinto
# LLM_API_KEY=
MODEL_NAME=gpt-4o-mini

# -------------------------------------------------------------
# VISIÓN — análisis de imágenes (multimodal)
# -------------------------------------------------------------
# VISION_BASE_URL=
# VISION_API_KEY=
VISION_MODEL=gpt-4o

# -------------------------------------------------------------
# EMBEDDINGS — RAG + caché semántico
# -------------------------------------------------------------
# EMBEDDINGS_BASE_URL=
# EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=text-embedding-3-small

# -------------------------------------------------------------
# STT — Speech-to-Text (Whisper)
# -------------------------------------------------------------
# STT_BASE_URL=
# STT_API_KEY=
STT_MODEL=whisper-1

# -------------------------------------------------------------
# TTS — Text-to-Speech
# -------------------------------------------------------------
# TTS_BASE_URL=
# TTS_API_KEY=
TTS_MODEL=tts-1
TTS_VOICE=nova

# -------------------------------------------------------------
# RAG
# -------------------------------------------------------------
RAG_URL=https://ayuda.nequi.com.co/preguntas-frecuentes
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# -------------------------------------------------------------
# Caché semántico
# -------------------------------------------------------------
SIMILARITY_THRESHOLD=0.90

# -------------------------------------------------------------
# Persistencia — rutas de archivos generados en runtime
# -------------------------------------------------------------
CACHE_DB_PATH=cache.db
FAISS_INDEX_PATH=faiss.index
FAISS_CHUNKS_PATH=faiss_chunks.json

# -------------------------------------------------------------
# Servidor
# -------------------------------------------------------------
PORT=8000
