# =============================================================
# FinBot — Variables de entorno
# Copia este archivo a .env y rellena los valores.
# =============================================================

# LLM Provider — OpenAI-compatible endpoint
# Ejemplos:
#   OpenAI:      BASE_URL=https://api.openai.com/v1
#   NVIDIA NIM:  BASE_URL=https://integrate.api.nvidia.com/v1
#   Ollama:      BASE_URL=http://localhost:11434/v1
#   Groq:        BASE_URL=https://api.groq.com/openai/v1
#   Together AI: BASE_URL=https://api.together.xyz/v1
BASE_URL=https://api.openai.com/v1
API_KEY=sk-...

# Modelos
MODEL_NAME=gpt-4o-mini
VISION_MODEL=gpt-4o
EMBEDDINGS_MODEL=text-embedding-3-small

# Voz
STT_MODEL=whisper-1
TTS_MODEL=tts-1
TTS_VOICE=nova

# RAG — URL a indexar al iniciar el servidor
RAG_URL=https://ayuda.nequi.com.co/preguntas-frecuentes
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# Cache semántico — umbral de similitud coseno (0.0–1.0)
SIMILARITY_THRESHOLD=0.90
